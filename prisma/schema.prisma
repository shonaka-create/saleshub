// Akane Hub — CRM / 案件管理 / 売上管理 統合システム
// マルチテナント: 全業務データは Organization (テナント) に属する。
// 区分値は String + src/lib/constants.ts の定数で管理する (SQLite時代の名残だが移行コスト回避のため維持)。
// テナント分離は Supabase (PostgreSQL) の RLS で強制する。ポリシーは scripts/apply-rls.ts を参照。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ===== テナント・ユーザー =====

model Organization {
  id           String   @id @default(cuid())
  name         String
  baseCurrency String   @default("JPY") // 全金額をこの通貨として扱う (売上管理・ダッシュボード・契約・案件共通)
  settings     String   @default("{}") // 機能カスタマイズ用 JSON (経営分析の閾値設定などもここ)
  createdAt    DateTime @default(now())

  // ===== 基本プラン (システム利用料: 初月無料 → 月額500円) =====
  // 無料期間は登録時に確定する。2026-07-15 (JST) までの登録 (earlyBird) は3ヶ月無料。
  basePlanStatus           String    @default("FREE") // FREE (未課金) | ACTIVE (課金中) | CANCELED (解約済)
  freeUntil                DateTime? // 無料期間の終了日時 (期限切れ & 未課金なら利用停止)
  earlyBird                Boolean   @default(false) // 早期登録特典 (3ヶ月無料) 対象
  stripeBaseSubscriptionId String?

  // ===== Pro プラン (経営分析) =====
  plan                 String    @default("FREE") // FREE | PRO
  trialEndsAt          DateTime? // 経営分析の14日無料トライアル終了日時 (ボタンから明示的に開始)
  stripeCustomerId     String?
  stripeSubscriptionId String?

  // ===== チームプラン (契約書/請求書/委託費管理 ＋ 今後のタスク/アサイン/WBS) =====
  // TEAM は Pro を包含する (teamPlan=TEAM なら Pro 機能も解放)。lib/plan.ts 参照。
  teamPlan                 String  @default("FREE") // FREE | TEAM
  stripeTeamSubscriptionId String?

  memberships       Membership[]
  invitations       Invitation[]
  services          Service[]
  customers         Customer[]
  deals             Deal[]
  contracts         Contract[]
  monthlyValues     MonthlyValue[]
  expenseCategories ExpenseCategory[]
  activities        Activity[]
  customFieldDefs   CustomFieldDef[]
  templates         Template[]
  contractStepDefs  ContractStepDef[]
  contractDocs      ContractDoc[]
  invoices          Invoice[]
  subcontractors    Subcontractor[]
  outsourcingWorks  OutsourcingWork[]
}

// 認証は Supabase Auth。id は auth.users.id (UUID) と一致させ、ここはプロフィール情報のみ持つ。
model User {
  id              String    @id
  email           String    @unique
  name            String
  isSystemAdmin   Boolean   @default(false) // サービス運営者 (/admin で全テナントの利用状況を閲覧可)
  termsAcceptedAt DateTime? // 利用規約・個人情報保護方針への同意日時 (登録時に記録)
  createdAt       DateTime  @default(now())

  memberships Membership[]
  activities  Activity[]
}

// サービス利用ログ (登録・課金・解約)。システム管理者画面専用で dbAdmin からのみ読み書きする。
// RLS は有効化しポリシーを与えない (akane_app からはアクセス不可)。
model BillingEvent {
  id        String   @id @default(cuid())
  orgId     String? // 組織削除後もログを残すため外部キーにしない
  orgName   String?
  email     String? // 操作したユーザーのメール
  type      String // REGISTER | BASE_SUBSCRIBED | BASE_CANCELED | PRO_SUBSCRIBED | PRO_CANCELED | PRO_TRIAL_STARTED
  detail    String   @default("")
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// 解約アンケートの構造化保存。BillingEvent と違い理由・改善希望を集計しやすい形で持ち、
// システム管理者画面の「契約管理」サマリの集計元になる。dbAdmin からのみ読み書きする
// (RLS 有効・ポリシーなし → akane_app からはアクセス不可)。
model CancellationSurvey {
  id            String   @id @default(cuid())
  orgId         String? // 組織削除後も回答を残すため外部キーにしない
  orgName       String?
  email         String? // 解約操作をしたユーザーのメール
  reason        String   @default("") // 解約の主な理由 (単一選択)
  improvements  String   @default("") // 改善希望 (複数選択を "・" 区切りで保存)
  detail        String   @default("") // 自由記述 (任意)
  wasSubscribed Boolean  @default(false) // 解約時点で課金中だったか (無料期間中の解約と区別)
  monthlyJpy    Int      @default(0) // 解約時点の月額 (課金中なら失った MRR)
  createdAt     DateTime @default(now())

  @@index([createdAt])
}

model Membership {
  id     String @id @default(cuid())
  userId String
  orgId  String
  role   String @default("MEMBER") // OWNER | ADMIN | MEMBER

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
}

model Invitation {
  id         String    @id @default(cuid())
  orgId      String
  email      String
  role       String    @default("MEMBER")
  token      String    @unique @default(cuid())
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

// ===== サービス・プランマスタ =====

model Service {
  id        String  @id @default(cuid())
  orgId     String
  name      String // 例: SNS運用 / サイト制作 / human-hub / tour-hub
  category  String  @default("OTHER") // SNS | WEB | SAAS | OTHER
  color     String  @default("#6366f1") // グラフ・バッジ表示色
  sortOrder Int     @default(0)
  archived  Boolean @default(false)

  org           Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  plans         Plan[]
  deals         Deal[]
  contracts     Contract[]
  monthlyValues MonthlyValue[]
}

model Plan {
  id         String  @id @default(cuid())
  serviceId  String
  name       String // 例: Plan A / Plan B / Pro
  initialFee Float   @default(0)
  monthlyFee Float   @default(0)
  active     Boolean @default(true)
  sortOrder  Int     @default(0)

  service   Service    @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  deals     Deal[]
  contracts Contract[]
}

// ===== CRM =====

model Customer {
  id         String   @id @default(cuid())
  orgId      String
  name       String
  country    String   @default("JP") // JP | AU | OTHER
  status     String   @default("LEAD") // LEAD | PROSPECT | ACTIVE | CHURNED
  industry   String? // 業種 (カフェ・サロン等)
  email      String?
  phone      String?
  instagram  String?
  website    String?
  address    String?
  tags       String   @default("") // カンマ区切り
  memo       String?
  customData String   @default("{}") // カスタム項目値 JSON
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  org          Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contacts     Contact[]
  deals        Deal[]
  contracts    Contract[]
  activities   Activity[]
  contractDocs ContractDoc[]
  invoices     Invoice[]
}

model Contact {
  id         String  @id @default(cuid())
  customerId String
  name       String
  role       String?
  email      String?
  phone      String?

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Activity {
  id         String   @id @default(cuid())
  orgId      String
  customerId String?
  dealId     String?
  userId     String?
  type       String   @default("NOTE") // NOTE | CALL | MEETING | EMAIL | TASK
  content    String
  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customer Customer?    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  deal     Deal?        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user     User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
}

// ===== 案件管理 =====

model Deal {
  id                String    @id @default(cuid())
  orgId             String
  customerId        String
  title             String
  stage             String    @default("LEAD") // LEAD | NEGOTIATION | PROPOSAL | WON | LOST
  serviceId         String?
  planId            String?
  initialFee        Float     @default(0)
  monthlyFee        Float     @default(0)
  probability       Int       @default(50) // 受注確度 %
  expectedCloseDate DateTime?
  closedAt          DateTime?
  lostReason        String?
  memo              String?
  sortOrder         Int       @default(0)
  customData        String    @default("{}")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customer   Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  service    Service?     @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  plan       Plan?        @relation(fields: [planId], references: [id], onDelete: SetNull)
  activities Activity[]
  contracts  Contract[]
}

// ===== 契約 (受注案件 → 月次売上の自動計算元) =====

model Contract {
  id         String    @id @default(cuid())
  orgId      String
  customerId String
  dealId     String?
  serviceId  String
  planId     String?
  name       String
  initialFee Float     @default(0) // 開始月に計上
  monthlyFee Float     @default(0) // 開始月〜終了月に毎月計上
  startDate  DateTime
  endDate    DateTime? // null = 継続中
  status     String    @default("ACTIVE") // ACTIVE | ENDED
  memo       String?
  createdAt  DateTime  @default(now())

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customer Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  deal     Deal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)
  service          Service           @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  plan             Plan?             @relation(fields: [planId], references: [id], onDelete: SetNull)
  steps            ContractStep[]
  contractDocs     ContractDoc[]
  outsourcingWorks OutsourcingWork[]
}

// ===== 契約手続きワークフロー (組織共通のチェックリストテンプレート) =====

model ContractStepDef {
  id        String  @id @default(cuid())
  orgId     String
  label     String // 例: 契約書送付, 署名回収, 初期費用請求, 入金確認, キックオフMTG
  sortOrder Int     @default(0)
  feature   String? // 定型プロセス種別 (constants.ts PROCEDURE_FEATURES: contract-doc | invoice | outsourcing-cost)。null は自由入力ステップ。

  org   Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  steps ContractStep[]
}

// 契約ごとの手続き完了状況。テンプレートに手順が追加された際は
// 遅延同期 (lib/contract-steps.ts) で不足分を補完する。
model ContractStep {
  id          String    @id @default(cuid())
  contractId  String
  stepDefId   String
  completedAt DateTime?

  contract Contract        @relation(fields: [contractId], references: [id], onDelete: Cascade)
  stepDef  ContractStepDef @relation(fields: [stepDefId], references: [id], onDelete: Cascade)

  @@unique([contractId, stepDefId])
}

// ===== 売上管理 (手入力・上書き・経費) =====

model ExpenseCategory {
  id        String @id @default(cuid())
  orgId     String
  name      String // 人件費・外注費 / 広告宣伝費 など
  sortOrder Int    @default(0)

  org           Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  monthlyValues MonthlyValue[]
}

// 月次グリッドのセル値。
// type=REVENUE_OVERRIDE: サービス別自動計算値の手動上書き (serviceId 必須)
// type=REVENUE_MANUAL:   自由行の手入力売上 (label 必須)
// type=EXPENSE:          経費 (expenseCategoryId 必須)
model MonthlyValue {
  id                String  @id @default(cuid())
  orgId             String
  month             String // "2026-07" 形式
  type              String
  serviceId         String?
  expenseCategoryId String?
  label             String?
  amount            Float
  memo              String?

  org             Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  service         Service?         @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  expenseCategory ExpenseCategory? @relation(fields: [expenseCategoryId], references: [id], onDelete: Cascade)

  @@index([orgId, month])
}

// ===== カスタム項目定義 =====

model CustomFieldDef {
  id        String @id @default(cuid())
  orgId     String
  entity    String // customer | deal
  key       String
  label     String
  type      String @default("text") // text | number | date | select
  options   String @default("[]") // select 用選択肢 JSON
  sortOrder Int    @default(0)

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, entity, key])
}

// ===== 契約書管理 (チーム機能) =====
// 論点: ①契約書を回せているか (送付/回付) ②同意を得ているか (締結) ③保管できているか
// 3つのチェックポイントを日付で持ち、締結・保管まで漏れなく回せているかを一覧で追えるようにする。
model ContractDoc {
  id           String    @id @default(cuid())
  orgId        String
  customerId   String? // 紐付け顧客 (任意)
  contractId   String? // 紐付け契約 (任意)
  title        String
  counterparty String    @default("") // 相手方 (顧客名など)
  sentAt       DateTime? // ① 契約書を送付・回付した日
  agreedAt     DateTime? // ② 相手方の同意 (署名・締結) を得た日
  storedAt     DateTime? // ③ 保管 (原本・PDF 格納) を完了した日
  fileUrl      String? // 保管先URL (Drive等・任意)
  filePath     String? // アップロードした実ファイルの Storage オブジェクトキー (attachments バケット)
  fileName     String? // アップロードファイルの元の名前 (ダウンロード時のファイル名)
  fileSize     Int       @default(0) // バイト
  mimeType     String? // アップロードファイルの MIME タイプ
  memo         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customer Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  contract Contract?    @relation(fields: [contractId], references: [id], onDelete: SetNull)

  @@index([orgId])
}

// ===== 請求書管理 (チーム機能) =====
// 論点: 受領/送付・必要項目・締切日への同意・締切日までの入金/支払い。
// direction で「発行(送付し入金を受ける)」と「受領(受け取り支払う)」を区別し、日付の意味を切り替える。
model Invoice {
  id             String    @id @default(cuid())
  orgId          String
  direction      String    @default("ISSUED") // ISSUED(発行/送付) | RECEIVED(受領)
  customerId     String? // 紐付け顧客 (発行時。任意)
  counterparty   String    @default("") // 取引先名 (発行=顧客 / 受領=委託先・仕入先)
  invoiceNo      String? // 請求書番号
  amount         Float     @default(0) // 税込金額
  taxRate        Float     @default(10)
  registrationNo String? // インボイス登録番号 (T+13桁)
  itemsComplete  Boolean   @default(false) // 必要項目 (登録番号・税率別金額・支払先等) を満たしているか
  issueDate      DateTime? // 請求日
  dueDate        DateTime? // 支払期限 (締切日)
  dueDateAgreed  Boolean   @default(false) // 締切日に双方が同意しているか
  deliveredAt    DateTime? // 発行=送付日 / 受領=受領日
  settledAt      DateTime? // 発行=入金日 / 受領=支払日
  filePath       String? // アップロードした請求書ファイルの Storage オブジェクトキー (attachments バケット)
  fileName       String? // アップロードファイルの元の名前
  fileSize       Int       @default(0) // バイト
  mimeType       String? // アップロードファイルの MIME タイプ
  memo           String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customer Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([orgId])
}

// ===== 委託費管理 (チーム機能) =====
// 論点: ①委託先の稼働を可視化 ②だれがいつ何を実施したか ③稼働を自社の費用として勘定できているか
model Subcontractor {
  id        String   @id @default(cuid())
  orgId     String
  name      String // 委託先名 (会社/個人)
  role      String? // 役割・職種 (デザイナー / エンジニア等)
  contact   String? // 連絡先
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  org   Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  works OutsourcingWork[]

  @@index([orgId])
}

// 委託先の稼働ログ。1行 = 「だれが・いつ・何を・いくら」。countedMonth で費用計上済みかを持つ。
model OutsourcingWork {
  id              String    @id @default(cuid())
  orgId           String
  subcontractorId String
  workedOn        DateTime // いつ
  performer       String    @default("") // だれが (委託先内の担当者名。空なら委託先名を使う)
  task            String // 何を実施したか
  hours           Float? // 稼働時間 (任意)
  amount          Float     @default(0) // 委託費 (費用計上額)
  contractId      String? // 紐付け契約 (任意)
  countedMonth    String? // 費用として勘定した月 (YYYY-MM)。null は未計上。
  memo            String?
  createdAt       DateTime  @default(now())

  org           Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  subcontractor Subcontractor @relation(fields: [subcontractorId], references: [id], onDelete: Cascade)
  contract      Contract?     @relation(fields: [contractId], references: [id], onDelete: SetNull)

  @@index([orgId])
}

// ===== テンプレートライブラリ (Word/PPT/Excel/PDF 等のファイル保管庫) =====
// 実ファイルは Supabase Storage の "templates" バケットに保存し、ここはメタデータのみ持つ。
// filePath は "{orgId}/{uuid}.{ext}" 形式で、パス先頭の orgId によってテナントを分離する。

model Template {
  id            String   @id @default(cuid())
  orgId         String
  name          String
  description   String?
  category      String   @default("OTHER") // PROPOSAL | QUOTE | CONTRACT | INVOICE | REPORT | OTHER
  fileName      String? // 元のファイル名 (ダウンロード時のファイル名に使う。URL登録時は null)
  filePath      String? // Supabase Storage 上のオブジェクトキー (URL登録時は null)
  sourceUrl     String? // 外部リンク登録の場合のURL (Canva / X / Notion 等。ファイル登録時は null)
  mimeType      String   @default("application/octet-stream")
  fileSize      Int      @default(0) // バイト
  downloadCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}
