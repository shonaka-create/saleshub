# Supabase プロジェクトの URL と API キー (Dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon key>"
SUPABASE_SERVICE_ROLE_KEY="<service_role key>"

# アプリ用接続 (RLS 適用ロール akane_app / transaction pooler)
DATABASE_URL="postgresql://akane_app.<project-ref>:<app-db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# 管理用接続 (postgres ロール / RLS バイパス。認証・招待フロー専用)
DATABASE_URL_ADMIN="postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# マイグレーション用 (session pooler / prisma db push・scripts/apply-rls.ts で使用)
DIRECT_URL="postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# akane_app ロールのパスワード (scripts/apply-rls.ts がロール作成・更新時に設定する)
APP_DB_PASSWORD="<app-db-password>"
